#!/usr/bin/env bash
set -euo pipefail

echo "=== Pre-commit checks ==="

# 1. Auto-format and re-stage
echo "[1/5] Formatting..."
gofmt -w .
goimports -w . 2>/dev/null || true
FORMATTED=$(git diff --name-only)
if [ -n "$FORMATTED" ]; then
    echo "  Auto-formatted files:"
    echo "$FORMATTED" | sed 's/^/    /'
    git add $FORMATTED
fi
echo "  OK"

# 2. Lint
echo "[2/5] Linting..."
golangci-lint run ./...
echo "  OK"

# 3. Vet
echo "[3/5] Vetting..."
go vet ./...
echo "  OK"

# 4. Tests with coverage
echo "[4/5] Testing with coverage..."
COVERAGE_THRESHOLD=95
COVERAGE_FILE=$(mktemp)
go test -race -coverprofile="$COVERAGE_FILE" -covermode=atomic ./... 2>&1

if [ -s "$COVERAGE_FILE" ]; then
    COVERAGE=$(go tool cover -func="$COVERAGE_FILE" | grep total | awk '{print $3}' | sed 's/%//')
    if [ -n "$COVERAGE" ]; then
        BELOW=$(echo "$COVERAGE < $COVERAGE_THRESHOLD" | bc -l)
        if [ "$BELOW" -eq 1 ]; then
            echo "  FAIL: Coverage ${COVERAGE}% is below ${COVERAGE_THRESHOLD}% threshold"
            rm -f "$COVERAGE_FILE"
            exit 1
        fi
        echo "  Coverage: ${COVERAGE}% (threshold: ${COVERAGE_THRESHOLD}%)"
    fi
fi
rm -f "$COVERAGE_FILE"
echo "  OK"

# 5. Dependency audit (warn only, do not block)
echo "[5/5] Dependency audit..."
if command -v govulncheck &> /dev/null; then
    govulncheck ./... 2>&1 || echo "  WARNING: Vulnerabilities found (non-blocking)"
else
    echo "  SKIP: govulncheck not installed"
fi
echo "  OK"

echo "=== All pre-commit checks passed ==="
